<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <link rel="icon" type="image/x-icon" href="/images/college-logo.svg">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Undertaking | Success</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap');

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Poppins', sans-serif;
            /* Exact background gradient matching the image */
            background: linear-gradient(90deg, #2a4f78 0%, #5a7d9f 100%);
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .container {
            display: flex;
            justify-content: center;
            align-items: center;
            width: 100%;
        }

        .popup {
            background: #ffffff;
            width: 100%;
            max-width: 480px;
            padding: 40px 30px;
            border-radius: 16px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.25);
            text-align: center;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 20px;
            animation: slideUp 0.5s ease-out forwards;
        }

        .icon-container {
            width: 90px;
            height: 90px;
            background-color: #10b981;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            box-shadow: 0 8px 20px rgba(16, 185, 129, 0.3);
            margin-bottom: 10px;
        }

        .icon-container i {
            color: #ffffff;
            font-size: 48px;
        }

        .div-item h2 {
            font-size: 2.2rem;
            font-weight: 700;
            color: #1f2937;
            margin-bottom: 10px;
        }

        .div-item p {
            font-size: 1.1rem;
            color: #4b5563;
            line-height: 1.6;
            margin-bottom: 25px;
        }

        .btn-next {
            display: inline-block;
            background-color: #10b981;
            color: #ffffff;
            text-decoration: none;
            font-size: 1.1rem;
            font-weight: 600;
            padding: 14px 40px;
            border-radius: 8px;
            transition: all 0.3s ease;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        }

        .btn-next:hover {
            background-color: #059669;
            transform: translateY(-2px);
            box-shadow: 0 6px 12px rgba(0, 0, 0, 0.15);
        }

        @keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @media only screen and (max-width: 480px) {
            .popup {
                padding: 30px 20px;
                width: 90%;
            }

            .icon-container {
                width: 70px;
                height: 70px;
            }

            .icon-container i {
                font-size: 36px;
            }

            .div-item h2 {
                font-size: 1.8rem;
            }

            .div-item p {
                font-size: 1rem;
            }
        }
    </style>
</head>

<body>
    <div class="container">
        <div class="popup" id="disp">
            <div class="icon-container">
                <i class="fa-solid fa-check"></i>
            </div>
            <div class="div-item">
                <h2>Thank You!</h2>
                <p>Student Undertaking saved successfully! Please proceed to the next step to complete your Fees Undertaking.</p>
                <a href="/feesUndertaking" class="btn-next">Next</a>
            </div>
        </div>
    </div>
</body>

</html>